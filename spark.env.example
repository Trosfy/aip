# aip spark — fleet backend config (EXAMPLE; placeholders only, no secrets)
#
# The real config lives OUT of the repo at ~/.config/aip/spark.env (mode 600),
# written by `aip install spark`. Never commit a real token or a private/CGNAT IP.
# This file documents the keys; copy it and fill in, or just run `aip install spark`.

# Fleet ingress ROOT (no trailing /v1 and no trailing slash; claude appends /v1/messages).
SPARK_BASE_URL=${SPARK_BASE_URL}

# Per-consumer LiteLLM VIRTUAL key (scoped + revocable). Never the gateway master key.
SPARK_TOKEN=${SPARK_TOKEN}

# Primary model seat; and the title/background "small fast" seat.
SPARK_MODEL=${SPARK_MODEL}
SPARK_SMALL_FAST_MODEL=${SPARK_SMALL_FAST_MODEL}

# Fleet seats the claude opus/sonnet/haiku tiers map to (consumer-side overrides).
SPARK_OPUS_MODEL=${SPARK_OPUS_MODEL}
SPARK_SONNET_MODEL=${SPARK_SONNET_MODEL}
SPARK_HAIKU_MODEL=${SPARK_HAIKU_MODEL}

# Harness (claude); escalation state (on/off); shim path recorded for clean uninstall.
SPARK_HARNESS=${SPARK_HARNESS}
SPARK_ESCALATION=${SPARK_ESCALATION}
SPARK_SHIM_PATH=${SPARK_SHIM_PATH}
